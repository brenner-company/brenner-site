{
  "text": {
    "fonts": {
      "$type": "fontFamily",
      "base": {
        "$value": "InterVariable, system-ui, sans-serif"
      },
      "accent": {
        "$value": "EuclidCircularB, system-ui, sans-serif"
      }
    },
    "sizes": {
      "$type": "fontSize",
      "heading": {
        "$value": "{type-scale.xl}"
      },
      "body": {
        "$value": "{type-scale.m}"
      }
    },
    "weights": {
      "$type": "fontWeight",
      "light": {
        "$value": "300"
      },
      "regular": {
        "$value": "400"
      },
      "semibold": {
        "$value": "600"
      },
      "bold": {
        "$value": "700"
      }
    },
    "lineHeights": {
      "$type": "number",
      "normal": {
        "$value": 1.2
      },
      "large": {
        "$value": 1.8
      }
    }
  }
}
