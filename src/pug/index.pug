//- settings (include)
include includes/settings.pug

//- content
doctype html
html(lang='en')
  head
    include includes/meta-doc.pug
    title #{site.name} - #{site.description}
    include includes/meta-seo.pug
    include includes/meta-brand.pug
    link(
      rel='stylesheet',
      href='/css/style.min.css'
    )
    include includes/fonts.pug
    script
      include ../js/analytics.js
  body
    include ../img/icon-defs.svg
    header.c-header
      .o-container
        .c-header__logo
          h1
            a(href='/').o-brand-logo
              img.o-brand-logo__img(src='/img/brenner-logo-rework.svg', alt=`${site.name}`)
              span.o-brand-logo__title #{site.name}
                span.u-hidden - #{site.description}
        include includes/navigation.pug
      
    main.main
      section.main__section.section--introduction
        h2 #{site.description}
        p Hi, my name is Karel Persoons and I am #[a(href='/') #[strong Brenner]], a one-person company from Ghent (Belgium) that provides coding &amp; consulting services on a freelance basis.
        p I’m always interested in exciting new projects. So feel free to #[a(href!=`mailto:${email}`) contact me].
        
      section.main__section
        h2='Some of my clients'
        include includes/clients.pug
        
      section.main__section
        h2='Development stack & tools'
        ul.naked-list.proficiencies-list
          li 
            h3 Design
            ul.proficiencies-list__sublist
              li Sketch
              li Affinity Designer
          
          li 
            h3 Building
            ul.proficiencies-list__sublist
              li CodeKit
              li Gulp
              
          li 
            h3 Coding
            ul.proficiencies-list__sublist
              li Emmet
              li Atom
              li Sublime Text
              
          li 
            h3 Languages
            ul.proficiencies-list__sublist
              li HTML (Jade)
              li CSS (SASS + Bourbon)
              li JavaScript
    footer.footer
      ul.naked-list.footer-list
        li
          a(href!=`mailto:${email}`)
            svg(class='icon icon--email')
              use(xlink:href='#email-icon')
            span.footer-list__item__title
              | !{email}